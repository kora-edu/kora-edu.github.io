source "https://rubygems.org"

# Specify your gemspec (e.g., for a Jekyll theme or plugin)
gemspec

# Essential Jekyll and GitHub Pages gems
gem "github-pages", group: :jekyll_plugins  # Ensures GitHub Pages compatibility
gem "jekyll-github-metadata", ">= 2.15"     # For GitHub metadata support

# Additional Jekyll plugins
gem "jekyll-include-cache", group: :jekyll_plugins  # Allows including cached content
gem "jekyll-sitemap", group: :jekyll_plugins        # Generates a sitemap for SEO

# Additional utilities
gem "html-proofer", "~> 5.0", group: :development   # Useful for validating HTML
gem "faraday-retry"                                 # Middleware for retrying failed HTTP requests
gem "csv"                                           # CSV library
gem "base64"                                        # Base64 encoding library
